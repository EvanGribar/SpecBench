{
  "name": "specbench",
  "version": "0.3.0-beta",
  "type": "module",
  "private": true,
  "description": "A local-first benchmark for product-requirement adherence in AI code review.",
  "packageManager": "pnpm@10.32.1",
  "engines": { "node": ">=20" },
  "scripts": {
    "validate": "tsx packages/cli/src/index.ts validate",
    "list": "tsx packages/cli/src/index.ts list",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build:reference": "pnpm --dir apps/reference-saas build",
    "specbench": "tsx packages/cli/src/index.ts",
    "specbench:local": "node --env-file-if-exists=.env.local --import tsx packages/cli/src/index.ts",
    "experiment:v0.3:smoke-preflight": "node --env-file-if-exists=.env.local --import tsx packages/cli/src/index.ts smoke-preflight",
    "experiment:v0.3:dry-run": "tsx packages/cli/src/index.ts experiment --all --dry-run",
    "experiment:v0.3:single-agent": "tsx packages/cli/src/index.ts experiment --config experiments/v0.3/single-agent.json",
    "experiment:v0.3:swarm-no-debate": "tsx packages/cli/src/index.ts experiment --config experiments/v0.3/swarm-no-debate.json",
    "experiment:v0.3:swarm-with-debate": "tsx packages/cli/src/index.ts experiment --config experiments/v0.3/swarm-with-debate.json",
    "experiment:v0.3:score": "tsx packages/cli/src/index.ts experiment-score",
    "experiment:v0.3:adjudicate": "tsx packages/cli/src/index.ts adjudicate",
    "experiment:v0.3:report": "tsx packages/cli/src/index.ts experiment-report-v03"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.0",
    "ai": "^6.0.0",
    "commander": "^13.1.0",
    "zod": "^3.24.3"
  }
}
