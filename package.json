{
  "name": "specbench",
  "version": "0.2.0",
  "type": "module",
  "private": true,
  "description": "A local-first benchmark for product-requirement adherence in AI code review.",
  "packageManager": "pnpm@10.32.1",
  "engines": { "node": ">=20" },
  "scripts": {
    "validate": "tsx packages/cli/src/index.ts validate",
    "list": "tsx packages/cli/src/index.ts list",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build:reference": "pnpm --dir apps/reference-saas build",
    "specbench": "tsx packages/cli/src/index.ts"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.0",
    "ai": "^6.0.0",
    "commander": "^13.1.0",
    "zod": "^3.24.3"
  }
}
